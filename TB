interface mul_if;
  logic [3:0]a;
  logic [3:0]b;
  logic [7:0]mul;
  logic clk;
endinterface

class transaction;
  randc bit [3:0]a;
  randc bit [3:0]b;
  bit [7:0]mul;
  
  function void display(input string name);
    $display("(%s)	a = %0d	b = %0d	mul = %0d",name,a,b,mul);
  endfunction
  
  function transaction copy();
    copy = new();
    copy.a = this.a;
    copy.b = this.b;
    copy.mul = this.mul;
  endfunction
endclass

class generator;
  transaction trans;
  mailbox #(transaction) mbx;
  event done;
  event stop;
  
  function new(mailbox #(transaction) mbx);
    this.mbx = mbx;
    trans = new();
  endfunction
  
  task run();
    for(int i=0;i<10;i++) begin
      trans.randomize();
      mbx.put(trans.copy);
      $display("[GEN] : DATA SENT");
      trans.display("GENERATOR");
      @(stop);
    end
    -> done;
  endtask
endclass

class driver;
  transaction data;
  virtual mul_if mif;
  mailbox #(transaction) mbx;
  
  function new(mailbox #(transaction) mbx);
    this.mbx = mbx;
  endfunction
  
  task run();
    forever begin
      mbx.get(data);
      @(posedge mif.clk);
      mif.a <= data.a;
      mif.b <= data.b;
      $display("[DRV] : INTERFACE TRIGGER");
      data.display("DRIVER");    
    end
  endtask
endclass

class monitor;
  mailbox #(transaction) mbx_ms;
  transaction trans;
  virtual mul_if mif;
  
  function new(mailbox #(transaction) mbx_ms);
    this.mbx_ms = mbx_ms;
  endfunction
  
  task run();
    trans = new();
    forever begin
      repeat(2) @(posedge mif.clk);
      trans.a = mif.a;
      trans.b = mif.b;
      @(posedge mif.clk);
      trans.mul = mif.mul;
      $display("[MON] : DATA SENT TO SCOREBOARD");
      mbx_ms.put(trans);
      trans.display("MONITOR");
    end
  endtask
endclass

class scoreboard;
  mailbox #(transaction) mbx_ms;
  transaction trans;
  event stop;
  
  function new(mailbox #(transaction) mbx_ms);
    this.mbx_ms = mbx_ms;
  endfunction
  
  task compare(input transaction trans);
    if((trans.mul) == (trans.a * trans.b)) 
      $display("[SCO] : MUL Result Matched");
    else
      $error("[SCO] : Result Mismatched");
  endtask
 
  task run();
    forever begin
      mbx_ms.get(trans);
      $display("[SCO] : DATA RCVD FROM MONITOR");
      trans.display("SCOREBOARD");
      compare(trans);
      ->stop;
      $display("-------------------------");
    end
  endtask
endclass
  
    

module tb;
  mul_if mif();
  driver drv;
  generator gen;
  scoreboard sc;
  monitor mt;
  event done;
  
  mailbox #(transaction) mbx;
  mailbox #(transaction) mbx_ms;
  top dut (mif.clk , mif.a , mif.b , mif.mul);
  
  initial begin
    mif.clk <= 0;
  end
  
  always #10 mif.clk <= ~mif.clk;
  
  initial begin
    mbx = new();
    mbx_ms = new();
    drv = new(mbx);
    gen = new(mbx);
    mt = new(mbx_ms);
    sc = new(mbx_ms);
    drv.mif = mif;
    mt.mif = mif;
    done = gen.done;
    gen.stop = sc.stop;
  end
  
  initial begin
    fork
      gen.run();
      drv.run();
      sc.run();
      mt.run();
    join_none
    wait(done.triggered);
    $finish();
  end
  
  initial begin
    $dumpfile("dump.vcd");
    $dumpvars;
  end
endmodule
    
      
    
    
    
  
    
